{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Skinora platform system overview — CPU, memory, uptime, and network across all services",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "CPU usage rate per service (process_cpu_seconds_total, 2m rate)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "CPU cores",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.9 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(process_cpu_seconds_total{job=\"skinora-backend\"}[2m])",
          "interval": "",
          "legendFormat": "Backend (.NET)",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(process_cpu_seconds_total{job=\"skinora-steam\"}[2m])",
          "interval": "",
          "legendFormat": "Steam Sidecar",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(process_cpu_seconds_total{job=\"skinora-blockchain\"}[2m])",
          "interval": "",
          "legendFormat": "Blockchain Sidecar",
          "refId": "C"
        }
      ],
      "title": "CPU Usage per Service",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Resident memory usage per service (process_resident_memory_bytes)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "Memory",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "red", "value": 536870912 }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_resident_memory_bytes{job=\"skinora-backend\"}",
          "interval": "",
          "legendFormat": "Backend (.NET)",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "process_resident_memory_bytes{job=\"skinora-steam\"}",
          "interval": "",
          "legendFormat": "Steam Sidecar",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "process_resident_memory_bytes{job=\"skinora-blockchain\"}",
          "interval": "",
          "legendFormat": "Blockchain Sidecar",
          "refId": "C"
        }
      ],
      "title": "Memory Usage per Service",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "How long each service process has been running (process_start_time_seconds)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 300 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "time() - process_start_time_seconds{job=\"skinora-backend\"}",
          "interval": "",
          "legendFormat": "Backend (.NET)",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "time() - process_start_time_seconds{job=\"skinora-steam\"}",
          "interval": "",
          "legendFormat": "Steam Sidecar",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "time() - process_start_time_seconds{job=\"skinora-blockchain\"}",
          "interval": "",
          "legendFormat": "Blockchain Sidecar",
          "refId": "C"
        }
      ],
      "title": "Service Uptime",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Network bytes received per service (rate over 2m). Available when container/process network metrics are exposed.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "Bytes/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 8 },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(container_network_receive_bytes_total{name=~\"skinora.*\"}[2m])",
          "interval": "",
          "legendFormat": "RX — {{name}}",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(container_network_transmit_bytes_total{name=~\"skinora.*\"}[2m])",
          "interval": "",
          "legendFormat": "TX — {{name}}",
          "refId": "B"
        }
      ],
      "title": "Network I/O (container_network_*)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Number of active HTTP requests currently being processed (ASP.NET Core: http_requests_in_progress, Node.js sidecars: custom gauge if exposed)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "Requests",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 8 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "http_requests_in_progress{job=\"skinora-backend\"}",
          "interval": "",
          "legendFormat": "Backend — in-progress",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "skinora_steam_http_requests_in_progress",
          "interval": "",
          "legendFormat": "Steam — in-progress",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "skinora_blockchain_http_requests_in_progress",
          "interval": "",
          "legendFormat": "Blockchain — in-progress",
          "refId": "C"
        }
      ],
      "title": "Active HTTP Requests",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["skinora", "system"],
