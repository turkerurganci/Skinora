# =============================================================================
# Skinora — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- General ---
NODE_ENV=development
ASPNETCORE_ENVIRONMENT=Development

# --- Backend (.NET) ---
BACKEND_PORT=5000

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- SQL Server ---
DB_PORT=1433
MSSQL_SA_PASSWORD=YourStrong!Password123
MSSQL_PID=Developer
DB_CONNECTION_STRING=Server=skinora-db,1433;Database=Skinora;User Id=sa;Password=YourStrong!Password123;TrustServerCertificate=True;

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=YourRedisPassword123
REDIS_CONNECTION_STRING=skinora-redis:6379,password=YourRedisPassword123

# --- Nginx ---
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

# --- Steam Sidecar ---
STEAM_SIDECAR_PORT=5100
STEAM_SIDECAR_BACKEND_URL=http://skinora-backend:5000
STEAM_API_KEY=your_steam_api_key_here

# --- Blockchain Sidecar ---
BLOCKCHAIN_SIDECAR_PORT=5200
BLOCKCHAIN_SIDECAR_BACKEND_URL=http://skinora-backend:5000
TRON_NETWORK=nile
TRON_FULL_NODE_URL=https://nile.trongrid.io
HD_WALLET_MNEMONIC=your_hd_wallet_mnemonic_here

# --- JWT ---
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_ISSUER=skinora
JWT_AUDIENCE=skinora-client
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
