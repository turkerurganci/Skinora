{
  "permissions": {
    "allow": [
      "Bash(npm init:*)",
      "Bash(npm install:*)",
      "WebFetch(domain:steamcommunity.com)",
      "WebSearch",
      "Edit(.claude/**)",
      "Edit(Docs/**)",
      "Edit(backend/**)",
      "Edit(frontend/**)",
      "Edit(sidecar-steam/**)",
      "Edit(sidecar-blockchain/**)",
      "Edit(infra/**)",
      "Edit(scripts/**)",
      "Edit(c:/projects/Escrow/**)",
      "Edit(C:/projects/Escrow/**)",
      "Edit(c:\\projects\\Escrow\\**)",
      "Edit(C:\\projects\\Escrow\\**)",
      "Edit(.claude/memory/MEMORY.md)",
      "Edit(c:/projects/Escrow/.claude/memory/MEMORY.md)",
      "Edit(C:/projects/Escrow/.claude/memory/MEMORY.md)",
      "Edit(c:\\projects\\Escrow\\.claude\\memory\\MEMORY.md)",
      "Edit(C:\\projects\\Escrow\\.claude\\memory\\MEMORY.md)",
      "Write(.claude/**)",
      "Write(Docs/**)",
      "Write(backend/**)",
      "Write(frontend/**)",
      "Write(sidecar-steam/**)",
      "Write(sidecar-blockchain/**)",
      "Write(infra/**)",
      "Write(scripts/**)",
      "Write(c:/projects/Escrow/**)",
      "Write(C:/projects/Escrow/**)",
      "Write(c:\\projects\\Escrow\\**)",
      "Write(C:\\projects\\Escrow\\**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(gh run:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet restore:*)",
      "PowerShell(git diff main...HEAD -- 'Backend/src/Skinora.Shared/Persistence/SystemSettingSeed.cs' | Out-String)",
      "PowerShell(git diff main...HEAD -- 'Docs/06_DATA_MODEL.md' | Out-String)",
      "PowerShell(dotnet test tests/Skinora.API.Tests/Skinora.API.Tests.csproj --filter \"FullyQualifiedName~AdminRbacEndpointTests\" --nologo --verbosity quiet 2>&1)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File ~/.claude/hooks/notify.ps1 -Message 'Claude finished — check the response'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File ~/.claude/hooks/notify.ps1 -Message 'Claude needs your attention'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/post-merge-ci-reminder.ps1",
            "shell": "powershell",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
