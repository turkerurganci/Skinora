#!/usr/bin/env bash
# Skinora pre-push hook — discipline-only branch protection + CI guard
#
# T11 close-out karari (2026-04-08): GitHub Free + private repo
# kombinasyonunda branch protection / rulesets paid feature oldugu icin
# sistem-enforced koruma yok. Bu hook lokal disiplin katmanidir.
#
# T11.2 (2026-04-12): CI guard katmani eklendi. Push edilen branch'in
# son CI run'i failure ise push bloklanir. gh CLI yoksa WARN + gecer.
#
# T11.2 follow-up (2026-04-12): Layer 3 — task branch isolation. task/TXX-*
# branch'i kendi TXX'i disinda bir task'a ait commit iceriyorsa push bloklanir
# (bundled-PR onlemesi). commit-msg hook birincil savunma, bu Layer son kontrol.
#
# Davranis:
# - Layer 1: main/develop'a direct push -> BLOCK + exit 1
# - Layer 2: push edilen branch'in son CI run'i failure -> BLOCK + exit 1
# - Layer 3: task/TXX-* branch yabanci TXX commit iceriyor -> BLOCK + exit 1
# - SKINORA_ALLOW_DIRECT_PUSH=1 -> Layer 1 + Layer 2 bypass + WARN
# - SKINORA_ALLOW_BUNDLED=1 -> Layer 3 bypass + WARN
# - Diger durumlar -> izin verir
#
# Kurulum: scripts/git-hooks/install.sh
#
# Bypass (acil durum / close-out commit'leri icin):
#   SKINORA_ALLOW_DIRECT_PUSH=1 git push origin main
#   SKINORA_ALLOW_DIRECT_PUSH=1 SKINORA_BYPASS_REASON="..." git push origin feature-branch

set -e

protected_branches="main develop"
remote="$1"
remote_url="$2"

log_bypass() {
  # $1 = branch name, $2 = reason prefix (e.g. "direct-push" or "ci-failure")
  local branch="$1"
  local kind="$2"
  local REPO_ROOT
  REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
  local LOG_FILE="$REPO_ROOT/Docs/BYPASS_LOG.md"
  if [ -f "$LOG_FILE" ]; then
    local TIMESTAMP
    TIMESTAMP="$(date -u '+%Y-%m-%d %H:%M UTC')"
    local GIT_USER
    GIT_USER="$(git config user.name || echo 'unknown')"
    local SHORT_SHA
    SHORT_SHA="$(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
    local REASON="${SKINORA_BYPASS_REASON:-*(sebep belirtilmedi)*}"
    echo "| $TIMESTAMP | $GIT_USER | $branch | \`$SHORT_SHA\` | [$kind] $REASON |" >> "$LOG_FILE"
    echo "BYPASS LOG: Docs/BYPASS_LOG.md'ye kayit eklendi ($kind)." >&2
    echo "  Lutfen bir sonraki normal commit'te bu dosyayi da commit'le." >&2
  fi
}

check_ci_status() {
  # $1 = branch name
  # Returns: "success" | "failure" | "none" | "skip"
  local branch="$1"

  if ! command -v gh >/dev/null 2>&1; then
    echo "skip"
    return 0
  fi

  if ! gh auth status >/dev/null 2>&1; then
    echo "skip"
    return 0
  fi

  local result
  result="$(gh run list --branch "$branch" --limit 1 --json conclusion,status 2>/dev/null || echo '[]')"

  if [ "$result" = "[]" ] || [ -z "$result" ]; then
    echo "none"
    return 0
  fi

  # Parse first run's conclusion without jq dependency
  local conclusion
  conclusion="$(echo "$result" | grep -o '"conclusion":"[^"]*"' | head -1 | cut -d'"' -f4)"
  local status
  status="$(echo "$result" | grep -o '"status":"[^"]*"' | head -1 | cut -d'"' -f4)"

  if [ "$status" != "completed" ]; then
    echo "none"
    return 0
  fi

  case "$conclusion" in
    success) echo "success" ;;
    failure|cancelled|timed_out|action_required|startup_failure) echo "failure" ;;
    *) echo "none" ;;
  esac
}

while read -r local_ref local_oid remote_ref remote_oid; do
  # --- Layer 1: Protected branch direct-push check ---
  pushing_branch="${remote_ref#refs/heads/}"
  is_protected=0
  for branch in $protected_branches; do
    if [ "$remote_ref" = "refs/heads/$branch" ]; then
      is_protected=1
      if [ "${SKINORA_ALLOW_DIRECT_PUSH:-0}" = "1" ]; then
        log_bypass "$branch" "direct-push"
        echo "WARN: SKINORA_ALLOW_DIRECT_PUSH=1 set — '$branch' direct push allowed." >&2
        echo "      Bu commit'in CI'dan gecmedigini unutma." >&2
      else
        cat <<EOF >&2

==============================================================================
ERROR: Direct push to '$branch' is blocked by Skinora pre-push hook.
==============================================================================

Skinora T11 close-out karari (discipline-only branch protection):
GitHub Free + private repo'da sistem-enforced branch protection paid
feature. Bu hook lokal disiplin katmanidir.

Korunan branch'ler: $protected_branches

Tum '$branch' degisiklikleri PR + CI uzerinden gitmelidir:
  1. Feature branch ac:        git checkout -b task/TXX-aciklama
  2. Degisiklikleri commit:    git commit -m "..."
  3. Branch'i push et:         git push -u origin task/TXX-aciklama
  4. PR ac:                    gh pr create --base $branch
  5. CI yesil olsun + validate chat PASS
  6. Squash merge:             gh pr merge <PR-no> --squash

Acil durum bypass (kullanmadan iki kez dusun):
  SKINORA_ALLOW_DIRECT_PUSH=1 git push origin $branch
  SKINORA_ALLOW_DIRECT_PUSH=1 SKINORA_BYPASS_REASON="aciklama" git push origin $branch

==============================================================================

EOF
        exit 1
      fi
    fi
  done

  # --- Layer 2: CI guard — current branch's last CI run must not be failure ---
  # T11.2: T13-T20 doneminde main CI ardisik FAIL sessizce devam etti.
  # Bu katman push oncesinde kirik CI'yi otomatik yakalar.
  ci_result="$(check_ci_status "$pushing_branch")"

  case "$ci_result" in
    success|none)
      : # push allowed
      ;;
    skip)
      echo "WARN: gh CLI bulunamadi veya auth yok — CI guard atlandi (branch: $pushing_branch)." >&2
      ;;
    failure)
      if [ "${SKINORA_ALLOW_DIRECT_PUSH:-0}" = "1" ]; then
        log_bypass "$pushing_branch" "ci-failure"
        echo "WARN: Son CI run failure — SKINORA_ALLOW_DIRECT_PUSH=1 ile gecildi." >&2
      else
        cat <<EOF >&2

==============================================================================
ERROR: Pre-push CI guard blocked push to '$pushing_branch'.
==============================================================================

Skinora T11.2 CI guard: son CI run'i failure/cancelled/timed_out.
T13-T20 doneminde main CI 5 task ustuste sessizce kirik kaldi; bu
katman o senaryonun bir daha olusmasini engeller.

Cozum:
  1. gh run list --branch $pushing_branch --limit 5
     (hangi adimin failed oldugunu gor)
  2. Root cause'u cozup yeniden push et
  3. Eger failure baska bir PR'dan geliyorsa, o PR'i once yesillendir

Acil durum bypass (kullanmadan iki kez dusun, BYPASS_LOG'a kayit dusulur):
  SKINORA_ALLOW_DIRECT_PUSH=1 SKINORA_BYPASS_REASON="..." git push origin $pushing_branch

==============================================================================

EOF
        exit 1
      fi
      ;;
  esac

  # --- Layer 3: Task branch isolation — only this task's TXX commits allowed ---
  # T11.2 follow-up (2026-04-12): T15/T16 (F0 Gate Check PR #10'a gomuldu) ve
  # T17-T19 (T20 PR #11'e gomuldu) bundled-PR ihlallerinin mekanik karsi-onlemi.
  # commit-msg hook'u birincil savunma, bu Layer push oncesi son kontrol.
  case "$pushing_branch" in
    task/T*)
      branch_txx="$(echo "$pushing_branch" | sed -nE 's|^task/(T[0-9]+(\.[0-9]+)?[a-z]?).*$|\1|p')"
      if [ -n "$branch_txx" ]; then
        found_txx="$(git log main..HEAD --format='%s' 2>/dev/null | grep -oE '^T[0-9]+(\.[0-9]+)?[a-z]?' | sort -u || true)"
        invalid_txx=""
        for txx in $found_txx; do
          if [ "$txx" != "$branch_txx" ]; then
            if [ -z "$invalid_txx" ]; then
              invalid_txx="$txx"
            else
              invalid_txx="$invalid_txx $txx"
            fi
          fi
        done

        if [ -n "$invalid_txx" ]; then
          if [ "${SKINORA_ALLOW_BUNDLED:-0}" = "1" ]; then
            log_bypass "$pushing_branch" "bundled-pr"
            echo "WARN: SKINORA_ALLOW_BUNDLED=1 — yabanci TXX referansi ($invalid_txx) izin verildi." >&2
          else
            cat <<EOF >&2

==============================================================================
ERROR: Pre-push branch isolation check FAILED.
==============================================================================

Branch:       $pushing_branch (task: $branch_txx)
Yabanci TXX:  $invalid_txx

Bu task branch'inde kendi TXX'i ($branch_txx) disinda baska bir task'a
ait commit(ler) mevcut. T11.2 retrospektifi T15/T16 (F0 Gate Check PR
#10'a bundled) ve T17-T19 (T20 PR #11'e bundled) ihlallerini ortaya
cikardi; bu hook o senaryonun bir daha olusmasini engeller.

Cozum:
  git log main..HEAD --oneline          # yabanci commit'leri goz ile tespit et
  git rebase -i main                    # yabanci commit'leri kaldir veya ayri branch'e tasi

Veya yabanci commit'leri yeni bir branch'e cherry-pick et:
  git checkout -b task/$invalid_txx-aciklama main
  git cherry-pick <yabanci-commit-sha>
  git checkout $pushing_branch
  git rebase -i main                    # yabanci commit'i $pushing_branch'ten sil

Acil durum bypass (kullanmadan iki kez dusun, BYPASS_LOG'a kayit dusulur):
  SKINORA_ALLOW_BUNDLED=1 SKINORA_BYPASS_REASON="..." git push origin $pushing_branch

==============================================================================

EOF
            exit 1
          fi
        fi
      fi
      ;;
  esac
done

exit 0
