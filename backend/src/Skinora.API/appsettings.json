{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Grafana.Loki"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://skinora-loki:3100",
          "labels": [
            { "key": "service", "value": "skinora-backend" },
            { "key": "environment", "value": "production" }
          ],
          "propertiesAsLabels": ["level"],
          "textFormatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": ["FromLogContext"],
    "Properties": {
      "service": "skinora-backend"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=Skinora;User Id=sa;Password=REPLACE_IN_ENV;TrustServerCertificate=True"
  },
  "Cors": {
    "AllowedOrigins": ["https://localhost:3000"]
  },
  "Jwt": {
    "Secret": "REPLACE_IN_ENV_minimum_32_characters",
    "Issuer": "skinora",
    "Audience": "skinora-client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "PreviousSecret": ""
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=REPLACE_IN_ENV,abortConnect=false"
  },
  "RateLimit": {
    "Enabled": true,
    "KeyPrefix": "skinora:ratelimit",
    "Policies": {
      "auth":            { "Limit": 10,  "WindowSeconds": 60 },
      "user-read":       { "Limit": 60,  "WindowSeconds": 60 },
      "user-write":      { "Limit": 20,  "WindowSeconds": 60 },
      "steam-inventory": { "Limit": 5,   "WindowSeconds": 60 },
      "admin-read":      { "Limit": 120, "WindowSeconds": 60 },
      "admin-write":     { "Limit": 30,  "WindowSeconds": 60 },
      "public":          { "Limit": 30,  "WindowSeconds": 60 }
    }
  }
}
